# ─── LLM ──────────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# GROQ model to use.
GROQ_MODEL=gpt-oss-120b

# ─── Email ────────────────────────────────────────────────────────────────────
# Gmail: use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=you@gmail.com

# ─── Push Notifications ───────────────────────────────────────────────────────
# Generate once by calling: GET /api/admin/generate-vapid  (with X-Admin-Key header)
# Then paste the output here.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:you@gmail.com

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of your app (used in email links)
APP_URL=http://localhost:8080
# Secret key for /api/admin/* endpoints (leave empty to disable auth in dev)
ADMIN_KEY=your-secret-key-here
# SQLite database path
DATABASE_URL=sqlite:///./data/topics.db
